# =============================================================================
# Test database container configuration
# docker compose automatically loads this file from the same directory.
# =============================================================================
# NOTE: Host ports use non-default values (15xxx / 13xxx / 18xxx) to avoid
# conflicts with locally-installed database services.

# PostgreSQL
POSTGRES_PORT=15432
POSTGRES_DB=test_db
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# MySQL
MYSQL_PORT=13306
MYSQL_DATABASE=test_db
MYSQL_USER=user
MYSQL_PASSWORD=password
MYSQL_ROOT_PASSWORD=rootpassword

# Oracle
ORACLE_PORT=11521
ORACLE_PASSWORD=Password123!

# MSSQL
MSSQL_PORT=11433
MSSQL_SA_PASSWORD=Password123!

# DB2
DB2_PORT=15000
DB2_PASSWORD=Password123!
DB2_DBNAME=test_db

# Apache Drill
DRILL_PORT=31010
DRILL_WEB_PORT=18047

# Trino
TRINO_PORT=18080
